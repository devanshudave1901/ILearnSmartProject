@{
    Layout = "~/Views/Shared/_AuthenticationLayout.cshtml";
    var errorMessage = ViewBag.ErrorMessage;
}
@model ILearnSmartProject.Models.Users

<div class="row d-flex align-items-center justify-content-center">
    <div class="col-md-4 ">
        <form>
            <div class="form-group">
                <label for="emailAddress">Email addresss</label>
                <input type="email" asp-for="EmailAddress" class="form-control" id="emailAddress" placeholder="name@example.com">
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                    <input type="password" asp-for="Password" class="form-control" id="password">
            </div>
            <button type="submit" asp-controller="Users" asp-action="LoginAttempt" class="btn btn-primary mt-5">Submit</button>
            @{
                    if(errorMessage != null)
                    {
                            <div class="alert alert-danger mt-5" role="alert">
                                @errorMessage + <a asp-controller="Users" asp-action="UserRegisteration">Register</a>
                            </div>
                    }
                }
            </form>
    </div>
</div>



