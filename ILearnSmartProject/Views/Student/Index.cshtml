<div class="row mt-5">
    @if(ViewBag.errorMessage != null)
    {
        <div class="alert alert-danger" role="alert">
            @ViewBag.errorMessage
        </div>
    }
    @if(course1 == null)
    {
        <div class="alert alert-danger" role="alert">
            No courses available
        </div>
    }
    else{
    @for (int i = 0; i < course1.Count; i++)
    {
        <div class="col-sm-3">
            <div class="card" style="width: 18rem;">
                <img src="../images/course1.jpg" class="card-img-top" alt="...">
                <div class="card-body">
                    <h5 class="card-title">@course1[i].CourseTitle</h5>
                    <p class="card-text">@course1[i].CourseDescription</p>
                    <p class="card-text">Price:- $@course1[i].CoursePrice</p>

                    <div class="d-flex justify-content-center">
                
                            <a asp-action="CheckoutPage" asp-controller="Student" asp-route-id="@course1[i].Id" class="btn btn-primary">Purchase</a>

                       
                    </div>
                </div>
            </div>
        </div>
        
        }
    }
    
</div>
<script>
    // document ready function to show the toast message if errorMessage is not null without jquery

    document.addEventListener("DOMContentLoaded", function () {
       

      setTimeout(() => {
          const elements = document.querySelectorAll('.card1');
          elements.forEach(el => el.style.display = 'none');
        }, 5000);
    });


</script>
